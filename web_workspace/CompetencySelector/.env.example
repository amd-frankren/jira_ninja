# ============================================================
# AMD Competency Selector – Environment Configuration
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ============================================================

# Internal AMD LLM endpoint URL
AI_ENDPOINT=https://llm-api.amd.com/OnPrem/chat/completions

# API subscription key (Ocp-Apim-Subscription-Key)
SUB_KEY=your_subscription_key_here

# User identifier sent with every AI request
API_USER=competency-selector-index-1

# API version – appended as ?api-version=<value>
API_VERSION=preview

# LLM model name
LLM_MODEL=GPT-oss-120B

# Maximum tokens in the AI response
LLM_MAX_TOKENS=1024

# Timeout for the upstream AI request in seconds (default: 90)
# Increase to 120+ if the model is slow or the prompt is long
AI_TIMEOUT=90

# Path to the feedback log file (default: feedback_logs.json in the project root)
FEEDBACK_LOG=feedback_logs.json

# Port the Flask server listens on (default: 5000)
PORT=5000

# Set to true only during local development (enables Flask debug mode & auto-reload)
DEBUG=false

# Deployment host IP displayed in logs and /api/health (does NOT affect binding)
# This is informational only – the actual binding IP is HOST above
DEPLOY_HOST=10.95.37.121

# ── JIRA API (primary – same auth as jira_monitor.py / scet_ticket_exporter.py) ──

# JIRA server base URL
JIRA_BASE_URL=https://ontrack.amd.com

# JIRA Personal Access Token (Bearer PAT)
# Generate at: https://ontrack.amd.com → Profile (top-right) → Personal Access Tokens
# Leave blank to use Service Account or SharePoint fallback
JIRA_TOKEN=

# JIRA Service Account credentials (IT-issued, Basic Auth)
# If JIRA_TOKEN is also set, JIRA_TOKEN takes priority.
# If only SERVICE_ACCOUNT is set, it will be used as Method 2.
JIRA_SERVICE_ACCOUNT_ID= a1_jira_analysis
JIRA_SERVICE_ACCOUNT_PASSWORD= \Y:4@c-2A0M8DHQgbY

# Timeout for JIRA API requests in seconds
JIRA_TIMEOUT=30

# ── SharePoint via Microsoft Graph (fallback – same auth as upload_to_sharepoint.py) ──
# Token priority: SHAREPOINT_ACCESS_TOKEN env → az account get-access-token (Azure CLI)
# One-time setup: run  az login --use-device-code --allow-no-subscriptions  on the server

# SharePoint hostname
SHAREPOINT_HOST_NAME=amdcloud.sharepoint.com

# SharePoint site path
SHAREPOINT_SITE_PATH=/sites/SCPI

# SharePoint Document Library name
SHAREPOINT_DRIVE_NAME=Documents

# Remote folder path inside the Document Library where SCET-XXXX.json files are stored
SHAREPOINT_REMOTE_FOLDER=SCETS/SCET_export_minified

# Manual Graph API token override (leave blank to use Azure CLI automatically)
SHAREPOINT_ACCESS_TOKEN=

# Timeout in seconds for SharePoint requests
SHAREPOINT_TIMEOUT=30
